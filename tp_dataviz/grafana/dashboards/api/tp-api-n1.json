{
  "uid": "tp-api-n1",
  "title": "TP – API Service Overview",
  "tags": ["tp", "api", "n1"],
  "timezone": "",
  "schemaVersion": 39,
  "version": 6,
  "editable": true,
  "refresh": "10s",
  "time": { "from": "now-6h", "to": "now" },
  "templating": {
    "list": [
      {
        "type": "datasource",
        "name": "DS_PROM",
        "label": "Prometheus",
        "query": "prometheus",
        "current": { "selected": true, "text": "Prometheus" }
      },
      {
        "type": "datasource",
        "name": "DS_LOKI",
        "label": "Loki",
        "query": "loki",
        "current": { "selected": true, "text": "Loki" }
      },
      {
        "type": "query",
        "name": "instance",
        "label": "API instance",
        "datasource": { "type": "prometheus", "uid": "${DS_PROM}" },
        "query": "label_values(up{job=\"demo_app\"}, instance)",
        "refresh": 1,
        "includeAll": false,
        "multi": false,
        "current": { "selected": true }
      },
      {
        "type": "query",
        "name": "node_instance",
        "label": "Node instance",
        "datasource": { "type": "prometheus", "uid": "${DS_PROM}" },
        "query": "label_values(node_uname_info, instance)",
        "refresh": 1,
        "includeAll": false,
        "multi": false,
        "current": { "selected": true }
      }
    ]
  },
  "panels": [
    {
      "id": 101,
      "type": "stat",
      "title": "API UP",
      "description": "Disponibilité de la cible applicative sélectionnée. Drilldown vers le panel N2 API UP.",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROM}" },
      "targets": [
        {
          "refId": "A",
          "expr": "max(up{job=\"demo_app\",instance=\"$instance\"}) or on() vector(0)"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": { "text": "DOWN", "color": "red" },
                "1": { "text": "UP", "color": "green" }
              }
            }
          ],
          "links": [
            {
              "title": "Voir le détail disponibilité (N2)",
              "url": "/d/tp-api-n2/tp-api-diagnostic?viewPanel=7&var-instance=${instance}&var-node_instance=${node_instance}",
              "targetBlank": false
            }
          ]
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "textMode": "auto"
      },
      "links": [
        {
          "title": "Voir le détail disponibilité (N2)",
          "url": "/d/tp-api-n2/tp-api-diagnostic?viewPanel=7&var-instance=${instance}&var-node_instance=${node_instance}",
          "targetBlank": false
        }
      ]
    },
    {
      "id": 102,
      "type": "stat",
      "title": "Traffic (req/s)",
      "description": "Débit applicatif calculé à partir de la recording rule de trafic. Drilldown vers le détail du trafic en N2.",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROM}" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(clamp_min(demo_app:http_requests:rate5m_total{instance=\"$instance\"}, 0)) or on() vector(0)"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "links": [
            {
              "title": "Voir le détail trafic (N2)",
              "url": "/d/tp-api-n2/tp-api-diagnostic?viewPanel=4&var-instance=${instance}&var-node_instance=${node_instance}",
              "targetBlank": false
            }
          ]
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "textMode": "value_and_name"
      },
      "links": [
        {
          "title": "Voir le détail trafic (N2)",
          "url": "/d/tp-api-n2/tp-api-diagnostic?viewPanel=4&var-instance=${instance}&var-node_instance=${node_instance}",
          "targetBlank": false
        }
      ]
    },
    {
      "id": 103,
      "type": "stat",
      "title": "Error Ratio %",
      "description": "Ratio erreurs 4xx/5xx sur la fenêtre 5m. Drilldown vers le détail des erreurs en N2.",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROM}" },
      "targets": [
        {
          "refId": "A",
          "expr": "(clamp_min(demo_app:http_errors:ratio5m, 0) or on() vector(0)) * 100"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "orange", "value": 2 },
              { "color": "red", "value": 5 }
            ]
          },
          "links": [
            {
              "title": "Voir le détail erreurs (N2)",
              "url": "/d/tp-api-n2/tp-api-diagnostic?viewPanel=3&var-instance=${instance}&var-node_instance=${node_instance}",
              "targetBlank": false
            }
          ]
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "textMode": "value_and_name"
      },
      "links": [
        {
          "title": "Voir le détail erreurs (N2)",
          "url": "/d/tp-api-n2/tp-api-diagnostic?viewPanel=3&var-instance=${instance}&var-node_instance=${node_instance}",
          "targetBlank": false
        }
      ]
    },
    {
      "id": 104,
      "type": "stat",
      "title": "Latency p95 (ms)",
      "description": "Latence p95 globale de l’API. Drilldown vers la latence détaillée par endpoint en N2.",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROM}" },
      "targets": [
        {
          "refId": "A",
          "expr": "(clamp_min(demo_app:http_request_duration_seconds:p95_5m, 0) or on() vector(0)) * 1000"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "orange", "value": 300 },
              { "color": "red", "value": 500 }
            ]
          },
          "links": [
            {
              "title": "Voir le détail latence (N2)",
              "url": "/d/tp-api-n2/tp-api-diagnostic?viewPanel=2&var-instance=${instance}&var-node_instance=${node_instance}",
              "targetBlank": false
            }
          ]
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "textMode": "value_and_name"
      },
      "links": [
        {
          "title": "Voir le détail latence (N2)",
          "url": "/d/tp-api-n2/tp-api-diagnostic?viewPanel=2&var-instance=${instance}&var-node_instance=${node_instance}",
          "targetBlank": false
        }
      ]
    },
    {
      "id": 105,
      "type": "stat",
      "title": "Host CPU %",
      "description": "Corrélation saturation CPU hôte ↔ latence API. Drilldown vers le panel CPU en N2.",
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROM}" },
      "targets": [
        {
          "refId": "A",
          "expr": "clamp_min(100 - (avg by(instance) (rate(node_cpu_seconds_total{job=~\"node_exporter_host|node_exporter_node2\",mode=\"idle\",instance=\"$node_instance\"}[5m])) * 100), 0) or on() vector(0)"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "orange", "value": 70 },
              { "color": "red", "value": 85 }
            ]
          },
          "links": [
            {
              "title": "Voir le détail CPU hôte (N2)",
              "url": "/d/tp-api-n2/tp-api-diagnostic?viewPanel=5&var-instance=${instance}&var-node_instance=${node_instance}",
              "targetBlank": false
            }
          ]
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "textMode": "value_and_name"
      },
      "links": [
        {
          "title": "Voir le détail CPU hôte (N2)",
          "url": "/d/tp-api-n2/tp-api-diagnostic?viewPanel=5&var-instance=${instance}&var-node_instance=${node_instance}",
          "targetBlank": false
        }
      ]
    },
    {
      "id": 106,
      "type": "text",
      "title": "Open Diagnostic Dashboard",
      "description": "Lien explicite vers le dashboard N2 complet.",
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 0 },
      "options": {
        "mode": "markdown",
        "content": "[👉 Ouvrir le dashboard N2 complet](/d/tp-api-n2/tp-api-diagnostic?var-instance=${instance}&var-node_instance=${node_instance})"
      }
    },
    {
      "id": 107,
      "type": "table",
      "title": "Top Slow Endpoints",
      "description": "Top 5 des handlers les plus lents. Drilldown vers la vue N2 des endpoints lents.",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROM}" },
      "targets": [
        {
          "refId": "A",
          "expr": "topk(5, clamp_min(demo_app:http_request_duration_seconds:p95_5m:by_handler, 0))",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "links": [
            {
              "title": "Voir le détail endpoints lents (N2)",
              "url": "/d/tp-api-n2/tp-api-diagnostic?viewPanel=2&var-instance=${instance}&var-node_instance=${node_instance}",
              "targetBlank": false
            }
          ]
        },
        "overrides": []
      },
      "options": {
        "showHeader": true,
        "footer": { "show": false }
      },
      "links": [
        {
          "title": "Voir le détail endpoints lents (N2)",
          "url": "/d/tp-api-n2/tp-api-diagnostic?viewPanel=2&var-instance=${instance}&var-node_instance=${node_instance}",
          "targetBlank": false
        }
      ]
    }
  ]
}