{
  "uid": "tp-api-n1",
  "title": "TP – API Service Overview",
  "tags": ["tp", "api", "n1"],
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-6h", "to": "now" },

  "templating": {
    "list": [
      {
        "type": "datasource",
        "name": "DS_PROM",
        "label": "Prometheus",
        "query": "prometheus",
        "current": { "selected": true }
      },
      {
        "type": "query",
        "name": "instance",
        "label": "Instance",
        "datasource": { "type": "prometheus", "uid": "${DS_PROM}" },
        "query": "label_values(up{job=\"demo_app\"}, instance)",
        "refresh": 1
      }
    ]
  },

  "panels": [

    {
      "type": "stat",
      "title": "API UP",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROM}" },
      "targets": [
        { "refId": "A", "expr": "up{job=\"demo_app\",instance=\"$instance\"}" }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": { "text": "DOWN", "color": "red" },
                "1": { "text": "UP", "color": "green" }
              }
            }
          ]
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" }
    },

    {
      "type": "stat",
      "title": "Traffic (req/s)",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROM}" },
      "targets": [
        { "refId": "A", "expr": "demo_app:http_requests:rate5m_total" }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } }
    },

    {
      "type": "stat",
      "title": "Error Ratio %",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROM}" },
      "targets": [
        { "refId": "A", "expr": "demo_app:http_errors:ratio5m * 100" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "orange", "value": 2 },
              { "color": "red", "value": 5 }
            ]
          }
        }
      }
    },

    {
      "type": "stat",
      "title": "Latency p95 (ms)",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROM}" },
      "targets": [
        { "refId": "A", "expr": "demo_app:http_request_duration_seconds:p95_5m * 1000" }
      ],
      "fieldConfig": { "defaults": { "unit": "ms" } }
    },

    {
      "type": "timeseries",
      "title": "Traffic",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 5 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROM}" },
      "targets": [
        { "refId": "A", "expr": "demo_app:http_requests:rate5m_total" }
      ]
    },

    {
      "type": "timeseries",
      "title": "Latency p95",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 5 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROM}" },
      "targets": [
        { "refId": "A", "expr": "demo_app:http_request_duration_seconds:p95_5m" }
      ]
    },

    {
      "type": "table",
      "title": "Top Slow Endpoints",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 13 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROM}" },
      "targets": [
        {
          "refId": "A",
          "expr": "topk(5, demo_app:http_request_duration_seconds:p95_5m:by_handler)"
        }
      ]
    }

  ]
}