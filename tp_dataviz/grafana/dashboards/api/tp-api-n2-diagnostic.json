{
  "uid": "tp-api-n2",
  "title": "TP – API Diagnostic",
  "tags": ["tp", "api", "diagnostic", "n2"],
  "timezone": "",
  "schemaVersion": 39,
  "version": 4,
  "editable": true,
  "refresh": "10s",
  "time": { "from": "now-6h", "to": "now" },
  "templating": {
    "list": [
      {
        "type": "datasource",
        "name": "DS_PROM",
        "label": "Prometheus",
        "query": "prometheus",
        "current": { "selected": true, "text": "Prometheus" }
      },
      {
        "type": "datasource",
        "name": "DS_LOKI",
        "label": "Loki",
        "query": "loki",
        "current": { "selected": true, "text": "Loki" }
      },
      {
        "type": "query",
        "name": "instance",
        "label": "API instance",
        "datasource": { "type": "prometheus", "uid": "${DS_PROM}" },
        "query": "label_values(up{job=\"demo_app\"}, instance)",
        "refresh": 1,
        "includeAll": false,
        "multi": false,
        "current": { "selected": true }
      },
      {
        "type": "query",
        "name": "node_instance",
        "label": "Node instance",
        "datasource": { "type": "prometheus", "uid": "${DS_PROM}" },
        "query": "label_values(node_uname_info, instance)",
        "refresh": 1,
        "includeAll": false,
        "multi": false,
        "current": { "selected": true }
      }
    ]
  },
  "panels": [
    {
      "type": "timeseries",
      "title": "Latency p95 by Instance",
      "description": "Latence p95 par instance applicative.",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROM}" },
      "targets": [
        {
          "refId": "A",
          "expr": "clamp_min(demo_app:http_request_duration_seconds:p95_5m:by_instance, 0) or vector(0)"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "links": [
            {
              "title": "Open in Explore (Prometheus)",
              "url": "/explore?left=%5B%22now-6h%22,%22now%22,%22${DS_PROM}%22,%7B%22queries%22:%5B%7B%22expr%22:%22demo_app:http_request_duration_seconds:p95_5m:by_instance%22,%22refId%22:%22A%22%7D%5D%7D%5D",
              "targetBlank": false
            }
          ]
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "single", "sort": "none" }
      }
    },
    {
      "type": "timeseries",
      "title": "Latency p95 by Endpoint",
      "description": "Latence p95 par handler/endpoint.",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROM}" },
      "targets": [
        {
          "refId": "A",
          "expr": "clamp_min(demo_app:http_request_duration_seconds:p95_5m:by_handler, 0) or vector(0)"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "links": [
            {
              "title": "Open in Explore (Prometheus)",
              "url": "/explore?left=%5B%22now-6h%22,%22now%22,%22${DS_PROM}%22,%7B%22queries%22:%5B%7B%22expr%22:%22demo_app:http_request_duration_seconds:p95_5m:by_handler%22,%22refId%22:%22A%22%7D%5D%7D%5D",
              "targetBlank": false
            }
          ]
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "single", "sort": "none" }
      }
    },
    {
      "type": "timeseries",
      "title": "Errors by Endpoint",
      "description": "Taux d’erreurs par endpoint pour identifier la route fautive.",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROM}" },
      "targets": [
        {
          "refId": "A",
          "expr": "clamp_min(sum by(handler) (rate(http_requests_total{job=\"demo_app\",code=~\"4..|5..\"}[5m])), 0) or vector(0)"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "links": [
            {
              "title": "Open in Explore (Prometheus)",
              "url": "/explore?left=%5B%22now-6h%22,%22now%22,%22${DS_PROM}%22,%7B%22queries%22:%5B%7B%22expr%22:%22sum%20by(handler)%20(rate(http_requests_total%7Bjob%3D%5C%22demo_app%5C%22,code%3D~%5C%224..%7C5..%5C%22%7D%5B5m%5D))%22,%22refId%22:%22A%22%7D%5D%7D%5D",
              "targetBlank": false
            }
          ]
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "single", "sort": "none" }
      }
    },
    {
      "type": "timeseries",
      "title": "Request Rate by Status Code",
      "description": "Répartition du trafic par code HTTP.",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROM}" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by(code) (rate(http_requests_total{job=\"demo_app\"}[5m])) or vector(0)"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps" },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "single", "sort": "none" }
      }
    },
    {
      "type": "stat",
      "title": "Host CPU %",
      "description": "Saturation CPU du node sélectionné.",
      "gridPos": { "h": 5, "w": 6, "x": 0, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROM}" },
      "targets": [
        {
          "refId": "A",
          "expr": "clamp_min(100 - (avg by(instance) (rate(node_cpu_seconds_total{mode=\"idle\",instance=\"$node_instance\"}[5m])) * 100), 0) or vector(0)"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "orange", "value": 70 },
              { "color": "red", "value": 85 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "none"
      }
    },
    {
      "type": "stat",
      "title": "Host Memory %",
      "description": "Utilisation mémoire du node sélectionné.",
      "gridPos": { "h": 5, "w": 6, "x": 6, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROM}" },
      "targets": [
        {
          "refId": "A",
          "expr": "((1 - (node_memory_MemAvailable_bytes{instance=\"$node_instance\"} / node_memory_MemTotal_bytes{instance=\"$node_instance\"})) * 100) or vector(0)"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "orange", "value": 75 },
              { "color": "red", "value": 90 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "none"
      }
    },
    {
      "type": "stat",
      "title": "API UP",
      "description": "État instantané de l’instance API sélectionnée.",
      "gridPos": { "h": 5, "w": 6, "x": 12, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROM}" },
      "targets": [
        {
          "refId": "A",
          "expr": "max(up{job=\"demo_app\",instance=\"$instance\"}) or vector(0)"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": { "text": "DOWN", "color": "red" },
                "1": { "text": "UP", "color": "green" }
              }
            }
          ]
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none"
      }
    },
    {
      "type": "stat",
      "title": "Current Error Ratio %",
      "description": "Ratio erreurs actuel pendant l’investigation.",
      "gridPos": { "h": 5, "w": 6, "x": 18, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROM}" },
      "targets": [
        {
          "refId": "A",
          "expr": "(clamp_min(demo_app:http_errors:ratio5m, 0) or vector(0)) * 100"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "orange", "value": 2 },
              { "color": "red", "value": 5 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "none"
      }
    },
    {
      "type": "logs",
      "title": "API Logs",
      "description": "Logs API généralistes pour corrélation métriques ↔ événements.",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 29 },
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "targets": [
        {
          "refId": "A",
          "expr": "{job=\"docker\"} |= \"demo\""
        }
      ],
      "options": {
        "showTime": true,
        "wrapLogMessage": true,
        "enableLogDetails": true
      },
      "links": [
        {
          "title": "Open in Explore (Loki)",
          "url": "/explore?left=%5B%22now-6h%22,%22now%22,%22${DS_LOKI}%22,%7B%22queries%22:%5B%7B%22expr%22:%22%7Bjob%3D%5C%22docker%5C%22%7D%20%7C%3D%20%5C%22demo%5C%22%22,%22refId%22:%22A%22,%22queryType%22:%22range%22%7D%5D%7D%5D",
          "targetBlank": false
        }
      ]
    },
    {
      "type": "logs",
      "title": "API Error Logs",
      "description": "Logs d’erreurs filtrés pour accélérer le diagnostic.",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 39 },
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "targets": [
        {
          "refId": "A",
          "expr": "{job=\"docker\"} |= \"error\""
        }
      ],
      "options": {
        "showTime": true,
        "wrapLogMessage": true,
        "enableLogDetails": true
      },
      "links": [
        {
          "title": "Open in Explore (Loki)",
          "url": "/explore?left=%5B%22now-6h%22,%22now%22,%22${DS_LOKI}%22,%7B%22queries%22:%5B%7B%22expr%22:%22%7Bjob%3D%5C%22docker%5C%22%7D%20%7C%3D%20%5C%22error%5C%22%22,%22refId%22:%22A%22,%22queryType%22:%22range%22%7D%5D%7D%5D",
          "targetBlank": false
        }
      ]
    }
  ]
}